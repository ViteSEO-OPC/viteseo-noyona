{
  "apiVersion": 3,
  "name": "noyona/faq-list",
  "version": "1.0.0",
  "title": "FAQ List",
  "category": "design",
  "icon": "editor-help",
  "description": "FAQ list with categories, search, and accordion items.",
  "supports": {
    "align": ["full", "wide"],
    "html": false
  },
  "attributes": {
    "heading": {
      "type": "string",
      "default": ""
    },
    "searchPlaceholder": {
      "type": "string",
      "default": ""
    },
    "searchButtonLabel": {
      "type": "string",
      "default": ""
    },
    "title": {
      "type": "string",
      "default": ""
    },
    "subtitle": {
      "type": "string",
      "default": ""
    },
    "categories": {
      "type": "array",
      "default": [
        { "label": "" },
        { "label": "" },
        { "label": "" },
        { "label": "" }
      ],
      "items": {
        "type": "object"
      }
    },
    "items": {
      "type": "array",
      "default": [
        {
          "question": "",
          "answer": "",
          "category": ""
        },
        {
          "question": "",
          "answer": "",
          "category": ""
        }
      ],
      "items": {
        "type": "object"
      }
    },
    "disclaimers": {
      "type": "array",
      "default": [
        {
          "title": "",
          "body": ""
        },
        {
          "title": "",
          "body": ""
        }
      ],
      "items": {
        "type": "object"
      }
    },
    "emptyMessage": {
      "type": "string",
      "default": ""
    },
    "showCommunityCta": { "type": "boolean", "default": false },
    "communityHeading": {
      "type": "string",
      "default": ""
    },
    "communityText": {
      "type": "string",
      "default": ""
    },
    "communityButtonText": { "type": "string", "default": "" },
    "communityButtonUrl": { "type": "string", "default": "" }

  },
  "style": "file:./style.css",
  "render": "file:./render.php",
  "viewScript": "file:./view.js",
  "textdomain": "noyona-childtheme"
}