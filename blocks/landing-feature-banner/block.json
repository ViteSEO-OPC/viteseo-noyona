{
  "apiVersion": 3,
  "name": "noyona/landing-feature-banner",
  "version": "1.0.0",
  "title": "Landing Feature Banner",
  "category": "design",
  "icon": "cover-image",
  "description": "Full-width landing banner with label, title, subheading, paragraph, and text position.",
  "supports": {
    "align": ["full", "wide"],
    "html": false
  },
  "attributes": {
    "label": { "type": "string", "default": "Noyona Essentials" },
    "title": { "type": "string", "default": "Best Face Makeup" },
    "subheading": { "type": "string", "default": "Discover Face Makeup Designed for Filipino Skin" },
    "paragraph": {
      "type": "string",
      "default": "Build your everyday glow with lightweight, skin-friendly formulas crafted for tropical weather and morena skin tones."
    },
    "backgroundImageDesktop": {
      "type": "string",
      "default": "/wp-content/themes/viteseo-noyona/assets/images/lp_products-desktop-1920x780px.webp"
    },
    "backgroundImageLaptop": {
      "type": "string",
      "default": "/wp-content/themes/viteseo-noyona/assets/images/lp_products-hero-laptop-1280x780px.webp"
    },
    "backgroundImageTablet": {
      "type": "string",
      "default": "/wp-content/themes/viteseo-noyona/assets/images/lp_products-hero-tablet-768x780px.webp"
    },
    "backgroundImageMobile": {
      "type": "string",
      "default": "/wp-content/themes/viteseo-noyona/assets/images/lp_products-hero-mobile-375x610px.webp"
    },
    "textPosition": { "type": "string", "default": "left" }
  },
  "style": "file:./style.css",
  "render": "file:./render.php",
  "textdomain": "noyona-childtheme"
}
