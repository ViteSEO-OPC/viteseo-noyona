{
  "apiVersion": 3,
  "name": "noyona/contact-form",
  "version": "1.0.0",
  "title": "Contact Form",
  "category": "design",
  "icon": "email",
  "description": "Community contact form with info card and map.",
  "supports": {
    "align": ["full", "wide"],
    "html": false
  },
  "attributes": {
    "heading": {
      "type": "string",
      "default": "<span class=\"contact-form__accent\">Connect</span> with our <span class=\"contact-form__accent\">Community</span>"
    },
    "subheading": {
      "type": "string",
      "default": "Stay updated on product drops, ingredient deep dives, application tips, and behind-the-scenes content from our team."
    },
    "leftTitle": {
      "type": "string",
      "default": "Let's Connect"
    },
    "brandImage": {
      "type": "string",
      "default": "/wp-content/themes/viteseo-noyona/assets/images/brand_with_a_purpose.webp"
    },
    "socials": {
      "type": "array",
      "default": [
        { "icon": "/wp-content/themes/viteseo-noyona/blocks/contact-form/assets/fb.png", "url": "https://facebook.com", "label": "Facebook" },
        { "icon": "/wp-content/themes/viteseo-noyona/blocks/contact-form/assets/tiktok.png", "url": "https://tiktok.com", "label": "TikTok" },
        { "icon": "/wp-content/themes/viteseo-noyona/blocks/contact-form/assets/instagram.png", "url": "https://instagram.com", "label": "Instagram" },
        { "icon": "/wp-content/themes/viteseo-noyona/blocks/contact-form/assets/lazada.png", "url": "https://www.lazada.com.ph", "label": "Lazada" },
        { "icon": "/wp-content/themes/viteseo-noyona/blocks/contact-form/assets/shopee.png", "url": "https://shopee.ph", "label": "Shopee" }
      ],
      "items": {
        "type": "object"
      }
    },
    "contactLabel": {
      "type": "string",
      "default": "Our Contact"
    },
    "phone": {
      "type": "string",
      "default": "0920 510 5555 "
    },
    "email": {
      "type": "string",
      "default": "info@noyonaessenitals.com"
    },
    "locationLabel": {
      "type": "string",
      "default": "Our Location"
    },
    "address": {
      "type": "string",
      "default": "Burgundy Corporate Tower 252 Sen. Gil Puyat Ave., Makati City, Metro Manila, Philippines"
    },
    "mapEmbedUrl": {
      "type": "string",
      "default": "https://maps.google.com/maps?q=Bustos%20Bulacan%20Philippines&t=&z=13&ie=UTF8&iwloc=&output=embed"
    },
    "mapNote": {
      "type": "string",
      "default": "View our store location to confirm address details, operating hours, and get turn-by-turn directions in one click."
    },
    "mapButtonText": {
      "type": "string",
      "default": "View Store Locations"
    },
    "mapButtonUrl": {
      "type": "string",
      "default": "/store-location/"
    },
    "formAction": {
      "type": "string",
      "default": ""
    },
    "formButtonText": {
      "type": "string",
      "default": "Submit Message"
    }
  },
  "style": "file:./style.css",
  "render": "file:./render.php",
  "textdomain": "noyona-childtheme"
}
