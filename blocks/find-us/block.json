{
  "$schema": "https://schemas.wp.org/wp/6.9/block.json",
  "name": "noyona/find-us",
  "apiVersion": 3,
  "version": "1.0.0",
  "title": "Find Us",
  "category": "noyona",
  "icon": "location",
  "description": "A block to highlight store location with an image.",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "image": {
      "type": "string",
      "default": "/wp-content/themes/viteseo-noyona/assets/images/brand-logo.webp"
    },
    "imageId": {
      "type": "number",
      "default": 0
    },
    "heading": {
      "type": "string",
      "default": "<span class=\"find-us__accent\">Where to Find Us</span>"
    },
    "description": {
      "type": "string",
      "default": "Visit our stores to experience Noyona products in person. Our beauty advisors are ready to help you find your perfect match."
    },
    "storeName": {
      "type": "string",
      "default": "Noyona Essentials"
    },
    "address": {
      "type": "string",
      "default": "Burgundy Corporate Tower 252 Sen. Gil Puyat Ave., Makati City, Metro Manila, Philippines"
    }
  },
  "style": "file:./style.css",
  "render": "file:./render.php"
}
