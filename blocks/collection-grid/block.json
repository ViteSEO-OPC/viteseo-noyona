{
  "apiVersion": 3,
  "name": "noyona/collection-grid",
  "version": "1.0.0",
  "title": "Collection Grid",
  "category": "design",
  "icon": "grid-view",
  "description": "Grid of collection cards with hover reveal for product count.",
  "supports": {
    "align": ["full", "wide"],
    "html": false
  },
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Our Collections"
    },
    "description": {
      "type": "string",
      "default": "Noyona offers makeup, hair, and body care essentials designed for Filipino skin tones, simple, effective, and confidence-boosting every day."
    },
    "headingAlign": {
      "type": "string",
      "default": "center"
    },
    "descriptionAlign": {
      "type": "string",
      "default": "center"
    },
    "buttonText": {
      "type": "string",
      "default": ""
    },
    "buttonUrl": {
      "type": "string",
      "default": ""
    },
    "buttonAlign": {
      "type": "string",
      "default": "center"
    },
    "items": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    }
  },
  "style": "file:./style.css",
  "render": "file:./render.php",
  "textdomain": "noyona-childtheme"
}
