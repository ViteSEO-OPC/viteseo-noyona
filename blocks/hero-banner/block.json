{
  "apiVersion": 3,
  "name": "noyona/hero-banner",
  "version": "1.0.0",
  "title": "Hero Banner",
  "category": "design",
  "icon": "cover-image",
  "description": "Wide hero banner with left-aligned text and background image.",
  "supports": {
    "align": ["full", "wide"],
    "html": false
  },
  "attributes": {
    "eyebrow": { "type": "string", "default": "" },
    "titleLine": { "type": "string", "default": "" },
    "body": { "type": "string", "default": "" },

    "searchEnabled": { "type": "boolean", "default": false },
    "searchPlaceholder": { "type": "string", "default": "" },
    "searchPostType": { "type": "string", "default": "" },

    "buttonText": { "type": "string", "default": "" },
    "buttonUrl": { "type": "string", "default": "" },

    "backgroundImageId": { "type": "number", "default": 0 },
    "backgroundImage": { "type": "string", "default": "" },
    "backgroundSize": { "type": "string", "default": "" },
    "backgroundPosition": { "type": "string", "default": "" },

    "backgroundImageMobileId": { "type": "number", "default": 0 },
    "backgroundImageMobile": { "type": "string", "default": "" },
    "backgroundSizeMobile": { "type": "string", "default": "" },
    "backgroundPositionMobile": { "type": "string", "default": "" },

    "backgroundColor": { "type": "string", "default": "" }
  },
  "style": "file:./style.css",
  "render": "file:./render.php",
  "textdomain": "noyona-childtheme"
}
