{
  "apiVersion": 3,
  "name": "noyona/newsletter-strip",
  "version": "1.0.1",
  "title": "Newsletter Strip",
  "category": "design",
  "icon": "email-alt",
  "description": "Reusable newsletter signup strip for page templates.",
  "supports": {
    "align": ["full", "wide"],
    "html": false
  },
  "attributes": {
    "heading": {
      "type": "string",
      "default": ""
    },
    "headingBefore": {
      "type": "string",
      "default": "Join the"
    },
    "headingAccent": {
      "type": "string",
      "default": "Noyona"
    },
    "headingAfter": {
      "type": "string",
      "default": "Family"
    },
    "subtitle": {
      "type": "string",
      "default": "Get notified to our exclusive updates, discounts, and more!"
    },
    "placeholder": {
      "type": "string",
      "default": "Your email address"
    },
    "buttonText": {
      "type": "string",
      "default": "Notify"
    },
    "showEmailInput": {
      "type": "boolean",
      "default": true
    },
    "formAction": {
      "type": "string",
      "default": "#"
    },
    "backgroundColor": {
      "type": "string",
      "default": "#FBDDE2"
    },
    "innerBorderColor": {
      "type": "string",
      "default": ""
    },
    "innerBorderWidth": {
      "type": "string",
      "default": "0"
    },
    "innerBorderStyle": {
      "type": "string",
      "default": "all"
    },
    "innerHeight": {
      "type": "string",
      "default": ""
    },
    "ctaTextColor": {
      "type": "string",
      "default": "#FFFFFF"
    },
    "ctaBackgroundColor": {
      "type": "string",
      "default": "#D91B61"
    },
    "ctaBorderColor": {
      "type": "string",
      "default": "#D91B61"
    },
    "ctaHoverTextColor": {
      "type": "string",
      "default": "#D91B61"
    },
    "ctaHoverBackgroundColor": {
      "type": "string",
      "default": "#FBDDE2"
    }
  },
  "style": "file:./style.css",
  "render": "file:./render.php",
  "textdomain": "noyona-childtheme"
}
