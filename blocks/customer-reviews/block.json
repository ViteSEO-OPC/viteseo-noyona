{
  "apiVersion": 3,
  "name": "noyona/customer-reviews",
  "version": "1.1.8",
  "title": "Customer Reviews Grid",
  "category": "design",
  "icon": "testimonial",
  "description": "Responsive customer reviews section with review cards and CTA links.",
  "supports": {
    "align": ["wide", "full"],
    "anchor": true,
    "html": false
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "wide"
    },
    "heading": {
      "type": "string",
      "default": "Customer Reviews"
    },
    "writeReviewText": {
      "type": "string",
      "default": "Write a Review"
    },
    "writeReviewUrl": {
      "type": "string",
      "default": "#"
    },
    "readMoreText": {
      "type": "string",
      "default": "Read More Reviews"
    },
    "readMoreUrl": {
      "type": "string",
      "default": "#"
    },
    "dataSource": {
      "type": "string",
      "default": "auto"
    },
    "sourceCategories": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "postsPerPage": {
      "type": "number",
      "default": 9
    },
    "initialVisible": {
      "type": "number",
      "default": 3
    },
    "showWriteReviewCta": {
      "type": "boolean",
      "default": true
    },
    "showReadMore": {
      "type": "boolean",
      "default": true
    },
    "showProductMeta": {
      "type": "boolean",
      "default": true
    },
    "showReviewForm": {
      "type": "boolean",
      "default": true
    },
    "emptyMessage": {
      "type": "string",
      "default": "No reviews yet."
    },
    "reviews": {
