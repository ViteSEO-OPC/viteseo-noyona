{
  "apiVersion": 3,
  "name": "noyona/terms",
  "version": "2.0.0",
  "title": "Terms Policy Page",
  "category": "design",
  "icon": "media-document",
  "description": "Reusable policy page block with hero, breadcrumb, TOC, and sections.",
  "supports": {
    "align": ["full", "wide"],
    "html": false
  },
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Terms & Policy"
    },
    "subheading": {
      "type": "string",
      "default": "At Noyona Cosmetics and Skin Care Products OPC, we prioritize transparency and trust by providing clear guidelines on how we handle your orders, protect your rights, and ensure a seamless shopping experience."
    },
    "breadcrumbRootLabel": {
      "type": "string",
      "default": "Terms & Policy"
    },
    "breadcrumbRootUrl": {
      "type": "string",
      "default": "/terms-of-services"
    },
    "breadcrumbCurrent": {
      "type": "string",
      "default": ""
    },
    "tocTitle": {
      "type": "string",
      "default": ""
    },
    "tocItems": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    },
    "contentTitle": {
      "type": "string",
      "default": "Terms of Service"
    },
    "intro": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "sections": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    }
  },
  "style": "file:./style.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php",
  "textdomain": "noyona-childtheme"
}
